<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="NonDeconstructibleAncientBuildingBase">
        <defName>RW_ApacheWreck</defName>
        <label>Apache Wreck</label>
        <description>An ancient, broken Apache. Restore it to gain a powerfull Helicopter.</description>
        <rotatable>false</rotatable>
        <graphicData>
            <texPath>Things/Wrecks/Apache</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(9,5)</drawSize>
        </graphicData>
        <size>(7,3)</size>
        <fillPercent>0.5</fillPercent>
        <castEdgeShadows>false</castEdgeShadows>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <statBases>
            <MaxHitPoints>600</MaxHitPoints>
            <Flammability>0</Flammability>
        </statBases>
        <killedLeavings>
            <ChunkSlagSteel>2</ChunkSlagSteel>
        </killedLeavings>
        <comps>
            <li Class="VanillaVehiclesExpanded.CompProperties_VehicleWreck">
                <vehicleDef>ROCKET_Apache</vehicleDef>
                <spawnRotation>East</spawnRotation>
            </li>
        </comps>
    </ThingDef>

